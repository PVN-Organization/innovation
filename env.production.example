# ┌──────────────────────────────────────────────────────────────────┐
# │  Innovation Portal — Production (.env for pvn-bcs-dev)          │
# │  Copy to .env on the server before running docker compose up.   │
# └──────────────────────────────────────────────────────────────────┘
#
# OFFLINE SERVER (no internet at all): use offline bundle instead
#   ./scripts/build-offline-bundle.sh  →  copy offline-bundle/  →  load-offline-bundle.sh
#   docker compose -f docker-compose.offline.yml up -d
#
# If "docker compose up --build" fails on apt-get: backend Dockerfile uses
# psycopg[binary] wheels only — no apt-get, no libpq system packages needed.
#
# ── Host Ports (avoid conflicts with existing services) ──────────
PG_HOST_PORT=5433
MINIO_API_HOST_PORT=9010
MINIO_CONSOLE_HOST_PORT=9011
BACKEND_HOST_PORT=10004
FRONTEND_HOST_PORT=10003

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=innovation
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
POSTGRES_DB=innovation_db

# ── MinIO / S3 Object Storage ────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<CHANGE_ME_STRONG_PASSWORD>
MINIO_BUCKET_NAME=innovations

# ── Azure AD SSO ─────────────────────────────────────────────────
AZURE_AD_CLIENT_ID=44fb46a1-23a0-4f92-9555-d25597cd9563
AZURE_AD_TENANT_ID=f49f790c-d831-46a2-898d-27902a8b490f
AZURE_AD_CLIENT_SECRET=<YOUR_CLIENT_SECRET>

# ── Backend (FastAPI) ────────────────────────────────────────────
SECRET_KEY=<CHANGE_ME_RANDOM_SECRET_64_CHARS>
DEBUG=false
BACKEND_CORS_ORIGINS=["https://sang-kien.pvn.io.vn"]
FRONTEND_URL=https://sang-kien.pvn.io.vn
COOKIE_SECURE=true

# ── Frontend (Next.js) ───────────────────────────────────────────
# Empty = use relative URLs (same origin via Caddy)
NEXT_PUBLIC_API_URL=

# ── Caddy (on server, not in this file) ───────────────────────────
# sang-kien.pvn.io.vn {
#     handle /api/* {
#         reverse_proxy 127.0.0.1:10004
#     }
#     handle {
#         reverse_proxy 127.0.0.1:10003
#     }
# }
#
# Azure AD Redirect URI:
# https://sang-kien.pvn.io.vn/api/v1/auth/callback
