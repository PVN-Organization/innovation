# ── Project ───────────────────────────────────────────────
PROJECT_NAME=Cổng Thông Tin Sáng Kiến Công Đoàn Petrovietnam
DEBUG=false

# ── Database ──────────────────────────────────────────────
POSTGRES_ASYNC_URL=postgresql+asyncpg://user:password@localhost:5432/innovation_db

# ── MinIO / S3 Object Storage ─────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=innovations

# ── Azure AD (Admin SSO) ─────────────────────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=

# ── Security ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
